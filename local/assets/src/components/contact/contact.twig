{% macro contact(classes) %}
	<section class="contact {{classes}} animate-block">
		<div class='contact__container'>
			<div class="contact__inner">
				<h2 class="contact__title text-50 fade-up" data-watch data-watch-once>Контакты</h2>
				<div class="contact__info fade-up" data-watch data-watch-once>
					<a href="javascript:void(0)" class="contact__link text-70">+7 916 602-91-93</a>
					<a href="javascript:void(0)" class="contact__link text-22">li3art@yandex.ru</a>
				</div>
				<div class="contact__content fade-up" data-watch data-watch-once>
					<div class="contact__content-title text-22">
						Соцсети:
					</div>
					<div class="contact__content-items">
						<div class="contact__content-item">
							<a href="javascript:void(0)" class="contact__content-link text-22">Телеграм</a>
						</div>
						<div class="contact__content-item">
							<a href="javascript:void(0)" class="contact__content-link text-22">Max</a>
						</div>
						<div class="contact__content-item">
							<a href="javascript:void(0)" class="contact__content-link text-22">Инстаграм</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endmacro %}
